<article data-next-link-card class="flex items-center justify-between gap-3 rounded-lg border bg-white px-4 py-3 shadow-sm">
  <div class="min-w-0">
    <a class="block truncate font-mono text-sm text-slate-900 hover:underline" href="{{ short_url }}">{{ short_url }}</a>
    <p class="truncate text-xs text-slate-500">→ {{ link.url }}</p>
  </div>
  <span class="shrink-0 rounded-full bg-slate-100 px-2 py-1 text-xs font-medium text-slate-700">
    {{ link.clicks }} clicks
  </span>
</article>
