<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>next.dj — URL shortener</title>
  <script src="https://cdn.tailwindcss.com"></script>
  {% collect_styles %}
</head>
<body class="bg-slate-50 text-slate-900">
  <header class="border-b bg-white">
    <nav class="mx-auto flex max-w-3xl items-center justify-between px-4 py-4">
      <a href="{% url 'next:page_' %}" class="text-lg font-semibold text-slate-900">
        🔗 next.dj shortener
      </a>
      {% component "nav_link" url_name="next:page_admin" active_when="page_admin" label="admin" class_base="text-sm" %}
    </nav>
  </header>

  <main class="mx-auto max-w-3xl px-4 py-8">
    {% block template %}{% endblock template %}
  </main>

  {% collect_scripts %}
</body>
</html>
