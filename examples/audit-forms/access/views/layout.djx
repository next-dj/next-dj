<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>next.dj — Audit-trail forms</title>
  <script src="https://cdn.tailwindcss.com"></script>
  {% collect_styles %}
</head>
<body class="bg-slate-50 text-slate-900">
  <header class="border-b bg-white">
    <nav class="mx-auto flex max-w-4xl items-center justify-between px-4 py-4">
      <a href="{% url 'next:page_' %}" class="text-lg font-semibold text-slate-900">
        🛂 next.dj access requests
      </a>
      <div class="flex items-center gap-4 text-sm">
        <a href="{% url 'next:page_' %}" class="text-slate-600 hover:text-slate-900">Home</a>
        <span class="text-slate-300">·</span>
        <a href="{% url 'next:page_request_step' step='applicant' %}" class="text-slate-600 hover:text-slate-900">
          Start request
        </a>
        <span class="text-slate-300">·</span>
        <a href="{% url 'next:page_admin_audit' %}" class="text-slate-600 hover:text-slate-900">Audit log</a>
      </div>
    </nav>
  </header>

  <main class="mx-auto max-w-4xl px-4 py-8">
    {% block template %}{% endblock template %}
  </main>

  {% collect_scripts %}
</body>
</html>
