<!DOCTYPE html>
<html lang="en">
{% component "page_head" title="next.dj — Audit-trail forms" %}
<body class="min-h-screen flex flex-col">
  {% #component "app_shell" brand="next.dj access requests" brand_href="/" brand_icon="🛂" %}
    {% #slot "actions" %}
      {% component "nav_link" url_name="next:page_" label="Home" variant="bar" %}
      {% component "nav_link" url="/request/applicant/" active_when="page_request_step" label="Start request" variant="bar" %}
      {% component "nav_link" url_name="next:page_admin_audit" label="Audit log" variant="bar" %}
    {% /slot %}
    {% #slot "content" %}
      {% block template %}{% endblock template %}
    {% /slot %}
  {% /component %}
  {% collect_scripts %}
</body>
</html>
