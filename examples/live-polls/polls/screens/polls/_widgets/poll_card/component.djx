<a href="/polls/{{ poll.pk }}/"
   class="poll-card block rounded-lg border border-slate-200 bg-white p-4 shadow-sm hover:border-slate-300 hover:shadow">
  <div class="text-xs uppercase tracking-wide text-slate-400">
    {{ poll.choice_count }} choices · {{ poll.total_votes }} total votes
  </div>
  <div class="mt-2 text-lg font-semibold text-slate-900">
    {{ poll.question }}
  </div>
  <div class="mt-1 text-xs text-slate-500">
    opened {{ poll.created_at|date:"M j, Y" }}
  </div>
</a>
