<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>next.dj — Live polls</title>
  <script src="https://cdn.tailwindcss.com"></script>
  {% collect_styles %}
</head>
<body class="bg-slate-100 text-slate-900">
  <header class="border-b bg-white">
    <nav class="mx-auto flex max-w-4xl items-center justify-between px-4 py-4">
      <a href="/polls/" class="text-lg font-semibold text-slate-900">
        🗳️ next.dj Live polls
      </a>
      <div class="text-sm text-slate-500">
        {{ active_polls_count }} open polls
      </div>
    </nav>
  </header>

  <main class="mx-auto max-w-4xl px-4 py-8">
    {% block template %}{% endblock template %}
  </main>

  {% collect_scripts %}
</body>
</html>
