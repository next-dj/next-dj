<div class="rounded-md border border-emerald-300 bg-emerald-50 p-3 text-sm"
     data-kanban-preview="{{ moved_card.id }}">
  <p class="font-medium text-emerald-800">Move complete</p>
  <p class="text-emerald-700">
    Card "{{ moved_card.title }}" landed in "{{ moved_card.column.title }}" at slot
    #{{ moved_card.position }}.
  </p>
</div>
