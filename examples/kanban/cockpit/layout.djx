<!DOCTYPE html>
<html lang="en">
{% component "page_head" title="next.dj — Kanban" %}
<body class="min-h-screen flex flex-col">
  {% #component "app_shell" brand="🗂️ next.dj Kanban" brand_href="/" %}
    {% #slot "actions" %}
      <span class="text-sm text-muted-foreground">
        {{ active_boards_count }} active boards
      </span>
    {% /slot %}
    {% #slot "content" %}
      {% block template %}{% endblock template %}
    {% /slot %}
  {% /component %}
  {% collect_scripts %}
</body>
</html>
