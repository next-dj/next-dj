<!DOCTYPE html>
<html lang="en">
{% #component "page_head" title="next.dj — Multi-tenant notes" tailwind_plugins="typography" %}
  {% #slot "extra" %}
    <style>
      .accent-bar { background: var(--tenant-accent, hsl(var(--primary))); }
      .accent-text { color: var(--tenant-accent, hsl(var(--primary))); }
      .accent-border { border-color: var(--tenant-accent, hsl(var(--primary))); }
    </style>
  {% /slot %}
{% /component %}
<body class="min-h-screen flex flex-col" style="{{ tenant_theme_css }}">
  <div class="accent-bar h-1 w-full"></div>
  {% component "header" %}

  <main class="mx-auto w-full max-w-container flex-1 px-4 py-8">
    {% block template %}{% endblock template %}
  </main>

  {% component "footer" %}
  {% collect_scripts %}
</body>
</html>
