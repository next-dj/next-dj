<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>next.dj — Markdown blog</title>
  <script src="https://cdn.tailwindcss.com"></script>
  {% collect_styles %}
</head>
<body class="bg-slate-50 text-slate-900">
  <header class="border-b bg-white">
    <div class="mx-auto max-w-3xl px-4 py-5">
      <div class="flex items-center justify-between">
        <a href="{% url 'next:page_' %}" class="text-lg font-semibold text-slate-900">
          ✒️ next.dj blog
        </a>
        <nav class="flex items-center gap-4">
          {% component "nav_link" url_name="next:page_" label="Home" %}
          {% component "nav_link" url_name="next:page_about" label="About" %}
        </nav>
      </div>
      <p class="mt-1 text-sm text-slate-500">{{ site_tagline }}</p>
    </div>
  </header>

  <main class="mx-auto max-w-3xl px-4 py-8">
    {% block template %}{% endblock template %}
  </main>

  <footer class="border-t bg-white py-6 text-center text-xs text-slate-500">
    © {{ site_year }} next.dj blog
  </footer>

  {% collect_scripts %}
</body>
</html>
