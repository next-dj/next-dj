{% if is_auth_page %}
  <main class="flex min-h-screen items-center justify-center px-4 py-12">
{% else %}
  <div class="flex min-h-screen w-full">
    {% component "admin_sidebar" brand="next.dj admin" app_list=app_list %}
    <div class="flex flex-1 flex-col">
      <header class="flex h-14 shrink-0 items-center justify-end border-b border-border bg-background px-6">
        <div class="flex items-center gap-3 text-sm">
          {% if user.is_authenticated %}
            <span class="text-muted-foreground">{{ user.get_username }}</span>
            {# Hand-crafted form: action_url resolves the dispatch URL by action name, the CSRF and origin fields the form tag would emit are written out by hand. #}
            <form action="{% action_url 'admin:logout' %}" method="post" class="inline">
              {% csrf_token %}
              <input type="hidden" name="_next_form_origin" value="{{ request.path }}">
              {% component "button" type="submit" text="Sign out" variant="outline" size="sm" %}
            </form>
          {% else %}
            {% component "button" href="/admin/login/" text="Sign in" variant="outline" size="sm" %}
          {% endif %}
        </div>
      </header>
      <main class="flex-1 overflow-y-auto px-6 py-8">
{% endif %}

{% component "flash_messages" %}
{% block template %}{% endblock template %}

{% if is_auth_page %}
  </main>
{% else %}
      </main>
    </div>
  </div>
{% endif %}
