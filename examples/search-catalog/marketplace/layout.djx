<!DOCTYPE html>
<html lang="en">
{% component "page_head" title="next.dj — Search catalog" %}
<body class="min-h-screen flex flex-col">
  {% #component "app_shell" brand="next.dj catalog" brand_href="/" brand_icon="🔍" %}
    {% #slot "actions" %}
      {% component "nav_link" url_name="next:page_catalog" label="All products" variant="bar" %}
    {% /slot %}
    {% #slot "content" %}
      {% block template %}{% endblock template %}
    {% /slot %}
  {% /component %}
  {% collect_scripts %}
</body>
</html>
