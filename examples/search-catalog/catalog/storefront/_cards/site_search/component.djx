<form method="get" action="{{ search_url }}" class="flex gap-2" data-site-search>
  <input
    type="search"
    name="q"
    value="{{ current_q }}"
    placeholder="Search products…"
    class="w-44 rounded-lg border px-3 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-slate-400"
  />
  <button
    type="submit"
    class="rounded-lg bg-slate-900 px-3 py-1.5 text-sm text-white hover:bg-slate-700"
  >
    Search
  </button>
</form>
