<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>next.dj — Feature flags admin</title>
  <script src="https://cdn.tailwindcss.com"></script>
  {% collect_styles %}
</head>
<body class="bg-slate-50 text-slate-900">
  <header class="border-b bg-white">
    <nav class="mx-auto flex max-w-4xl items-center justify-between px-4 py-4">
      <a href="{% url 'next:page_' %}" class="text-lg font-semibold text-slate-900">
        🚩 next.dj flags
      </a>
      <div class="flex items-center gap-4 text-sm">
        {% component "nav_link" url_name="next:page_" label="Active" %}
        <span class="text-slate-300">·</span>
        {% component "nav_link" url_name="next:page_admin" active_when="page_admin" label="Admin" %}
        <span class="text-slate-300">·</span>
        {% component "nav_link" url_name="next:page_demo" label="Demo" %}
      </div>
    </nav>
  </header>

  <main class="mx-auto max-w-4xl px-4 py-8">
    {% block template %}{% endblock template %}
  </main>

  {% collect_scripts %}
</body>
</html>
